
include "/usr/local/BIPLAN/graphics.biplan"
include "/usr/local/BIPLAN/ansi.biplan"

macro WIDTH  99
macro HEIGHT 33

for #i = 0 to WIDTH * HEIGHT
  mem[#i] = '$' + random 80
next

print restart

@t = ansi_color(ANSI_GREEN)
@c = ansi_cursor(false)

for #z = 0 to HEIGHT
  for #x = 0 to WIDTH
    for #y = 0 to random #z + 1
      print cursor #x, #y
      print char mem[#x + (#y * WIDTH)]
    next
    delay 1
  next
next

ansi_cursor(true)
ansi_style(ANSI_REGULAR)

print cursor 0, 35

stop
