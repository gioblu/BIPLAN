include "/usr/local/BIPLAN/strings.biplan"

:s = "This is a test string"

print "Printing entire string: ", :s

print "\nPrinting string character by character: "

for #i = 0 to size :s
	print char :s[#i]
next

print "\nPrinting string from \"a\" onwards: "

@p = find_char(:s, 'a')

for #i = @p to size :s
	print char :s[#i]
next

print "\n"

stop